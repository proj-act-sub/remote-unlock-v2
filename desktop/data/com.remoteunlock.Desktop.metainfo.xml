<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.remoteunlock.Desktop</id>
  <name>RemoteUnlock</name>
  <summary>Biometric remote screen unlock for GNOME</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <description>
    <p>
      Unlock your GNOME screen from your Android phone using biometrics.
      Uses the Noise IK protocol with BLAKE3 and X25519 — similar to WireGuard.
    </p>
  </description>
  <url type="homepage">https://github.com/proj-act-sub/crispy-guide</url>
  <releases>
    <release version="7.0.0" date="2026-03-30"/>
  </releases>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>
</component>
